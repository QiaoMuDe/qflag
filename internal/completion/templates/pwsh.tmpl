# -------------------------- Configuration Area (Need to be modified according to actual commands) --------------------------
# Command name
${{.SanitizedName}}_commandName = "{{.ProgramName}}"

# 1. Command tree structure
${{.SanitizedName}}_cmdTree = @(
{{.CmdTree}}
)

# 2. Flag parameter definitions
${{.SanitizedName}}_flagParams = @(
{{.FlagParams}}
)

# -----------------------------------------------------------------------------------

# ==================== Fuzzy Completion Configuration Parameters ====================
# Fuzzy completion feature switch (set to $false to disable, $true to enable)
$script:{{.SanitizedName}}_FUZZY_COMPLETION_ENABLED = $true

# Maximum candidate count threshold for enabling fuzzy completion
# Falls back to traditional prefix matching when exceeded to ensure performance
$script:{{.SanitizedName}}_FUZZY_MAX_CANDIDATES = 120

# Minimum input length for fuzzy matching (fuzzy matching disabled below this length)
$script:{{.SanitizedName}}_FUZZY_MIN_PATTERN_LENGTH = 2

# Fuzzy matching score threshold (0-100, matches below this score will be filtered)
$script:{{.SanitizedName}}_FUZZY_SCORE_THRESHOLD = 25

# Maximum number of fuzzy matching results to return
$script:{{.SanitizedName}}_FUZZY_MAX_RESULTS = 10

# Cache size control parameter
# Cache will be cleared when entry count exceeds this threshold to prevent unlimited memory growth
$script:{{.SanitizedName}}_FUZZY_CACHE_MAX_SIZE = 500

# Fuzzy matching result cache (format: "pattern|candidate" -> score)
$script:{{.SanitizedName}}_fuzzyCache = @{}

# ==================== Fuzzy Matching Core Algorithm ====================

# High-performance fuzzy scoring function - uses optimized string operations
# Parameters: $Pattern=input pattern, $Candidate=candidate string
# Returns: Integer score from 0-100
function Get-{{.SanitizedName}}FuzzyScoreFast {
    param(
        [string]$Pattern,
        [string]$Candidate
    )
    
    $patternLen = $Pattern.Length
    $candidateLen = $Candidate.Length
    
    # Fast path 1: Empty pattern check
    if ($patternLen -eq 0) {
        return 100
    }
    
    # Performance optimization 1: Length pre-check - return 0 if candidate is too short
    if ($candidateLen -lt $patternLen) {
        return 0
    }
    
    # Performance optimization 2: Exact match check - avoid unnecessary complex calculations
    if ($Candidate.StartsWith($Pattern, [System.StringComparison]::OrdinalIgnoreCase)) {
        return 100  # Give highest score for exact prefix match
    }
    
    # Memory access optimization: Pre-convert to char arrays to avoid repeated string indexing
    $patternLower = $Pattern.ToLowerInvariant()
    $candidateLower = $Candidate.ToLowerInvariant()
    $patternChars = $patternLower.ToCharArray()
    $candidateChars = $candidateLower.ToCharArray()
    
    # Fast path 2: Single character match optimization
    if ($patternLen -eq 1) {
        for ($i = 0; $i -lt $candidateLen; $i++) {
            if ($candidateChars[$i] -eq $patternChars[0]) {
                return 100 - $i  # Higher score for earlier position
            }
        }
        return 0
    }
    
    # Performance optimization 3: Character existence pre-check - quickly exclude impossible matches
    # Use char array access instead of string indexing to reduce memory overhead
    foreach ($char in $patternChars) {
        $found = $false
        foreach ($candidateChar in $candidateChars) {
            if ($candidateChar -eq $char) {
                $found = $true
                break
            }
        }
        if (-not $found) {
            return 0  # Required character doesn't exist, return immediately
        }
    }
    
    # Core matching algorithm - calculate character match degree and continuity
    $matched = 0           # Number of matched characters
    $consecutive = 0       # Current consecutive match length
    $maxConsecutive = 0    # Maximum consecutive match length
    $candidatePos = 0      # Current search position in candidate string
    $startBonus = 0        # Starting position bonus
    
    # Check if matches from beginning (case-insensitive) - using char arrays is more efficient
    $startsWithPattern = $true
    if ($patternLen -le $candidateLen) {
        for ($i = 0; $i -lt $patternLen; $i++) {
            if ($patternChars[$i] -ne $candidateChars[$i]) {
                $startsWithPattern = $false
                break
            }
        }
        if ($startsWithPattern) {
            $startBonus = 20  # Give 20 points bonus for starting match
        }
    }
    
    # Character-by-character matching algorithm - using pre-converted char arrays reduces memory access overhead
    for ($i = 0; $i -lt $patternLen; $i++) {
        $patternChar = $patternChars[$i]
        $found = $false
        
        # Search for current pattern character in candidate string
        for ($j = $candidatePos; $j -lt $candidateLen; $j++) {
            if ($candidateChars[$j] -eq $patternChar) {
                $matched++
                $found = $true
                
                # Continuity check - consecutive matching characters score higher
                if ($j -eq $candidatePos) {
                    $consecutive++
                    if ($consecutive -gt $maxConsecutive) {
                        $maxConsecutive = $consecutive
                    }
                } else {
                    $consecutive = 1  # Reset consecutive count
                }
                
                $candidatePos = $j + 1  # Update search position
                break
            }
        }
        
        # Reset consecutive count if character not found
        if (-not $found) {
            $consecutive = 0
        }
    }
    
    # Score calculation - use integer arithmetic
    # Base score: (matched characters / pattern length) * 60
    $baseScore = [Math]::Floor(($matched * 60) / $patternLen)
    
    # Consecutive bonus: (max consecutive length / pattern length) * 20
    $consecutiveBonus = [Math]::Floor(($maxConsecutive * 20) / $patternLen)
    
    # Length penalty: longer candidate strings get slightly lower scores
    $lengthPenalty = [Math]::Min(($candidateLen - $patternLen), 10)
    
    # Final score calculation
    $finalScore = $baseScore + $consecutiveBonus + $startBonus - $lengthPenalty
    
    # Ensure score is within 0-100 range
    return [Math]::Max(0, [Math]::Min(100, $finalScore))
}

# Cached fuzzy scoring function - avoids repeated calculations to improve performance
# Parameters: $Pattern=input pattern, $Candidate=candidate string
function Get-{{.SanitizedName}}FuzzyScoreCached {
    param(
        [string]$Pattern,
        [string]$Candidate
    )
    
    $cacheKey = "$Pattern|$Candidate"
    
    # Cache hit check
    if ($script:{{.SanitizedName}}_fuzzyCache.ContainsKey($cacheKey)) {
        return $script:{{.SanitizedName}}_fuzzyCache[$cacheKey]
    }
    
    # Calculate score and cache
    $score = Get-{{.SanitizedName}}FuzzyScoreFast -Pattern $Pattern -Candidate $Candidate
    
    # Cache size control - prevent unlimited memory growth
    if ($script:{{.SanitizedName}}_fuzzyCache.Count -gt $script:{{.SanitizedName}}_FUZZY_CACHE_MAX_SIZE) {
        $script:{{.SanitizedName}}_fuzzyCache.Clear()  # Clear cache
    }
    
    $script:{{.SanitizedName}}_fuzzyCache[$cacheKey] = $score
    return $score
}

# Intelligent completion matching function - refactored matching strategy
# Parameters: $Pattern=input pattern, $Options=candidate options array
function Get-{{.SanitizedName}}IntelligentMatches {
    param(
        [string]$Pattern,
        [array]$Options
    )
    
    $patternLen = $Pattern.Length
    $totalCandidates = $Options.Count
    
    # Return all options when pattern is empty (for initial Tab completion state)
    if ([string]::IsNullOrEmpty($Pattern)) {
        return $Options
    }
    
    # New intelligent matching strategy: Multi-level progressive matching
    
    # Level 1: Exact prefix matching (highest priority)
    $exactPrefixMatches = [System.Collections.ArrayList]::new()
    foreach ($option in $Options) {
        if ($option.StartsWith($Pattern, [System.StringComparison]::Ordinal)) {
            [void]$exactPrefixMatches.Add($option)
        }
    }
    
    # If there are exact prefix matches, return them first (but don't limit quantity too much)
    if ($exactPrefixMatches.Count -gt 0) {
        return $exactPrefixMatches.ToArray()
    }
    
    # Level 2: Case-insensitive prefix matching
    $caseInsensitiveMatches = [System.Collections.ArrayList]::new()
    foreach ($option in $Options) {
        if ($option.StartsWith($Pattern, [System.StringComparison]::OrdinalIgnoreCase)) {
            [void]$caseInsensitiveMatches.Add($option)
        }
    }
    
    # If there are case-insensitive matches, return
    if ($caseInsensitiveMatches.Count -gt 0) {
        return $caseInsensitiveMatches.ToArray()
    }
    
    # Level 3: Substring matching (basic fuzzy matching) - re-added
    $substringMatches = [System.Collections.ArrayList]::new()
    $patternLower = $Pattern.ToLowerInvariant()
    foreach ($option in $Options) {
        if ($option.ToLowerInvariant().Contains($patternLower)) {
            [void]$substringMatches.Add($option)
        }
    }
    
    # If there are substring matches, return
    if ($substringMatches.Count -gt 0) {
        return $substringMatches.ToArray()
    }
    
    # Level 4: Smart fuzzy matching (advanced fuzzy matching)
    if ($script:{{.SanitizedName}}_FUZZY_COMPLETION_ENABLED -and $patternLen -ge $script:{{.SanitizedName}}_FUZZY_MIN_PATTERN_LENGTH -and $totalCandidates -le $script:{{.SanitizedName}}_FUZZY_MAX_CANDIDATES) {
        $scoredMatches = [System.Collections.ArrayList]::new()
        
        foreach ($option in $Options) {
            $score = Get-{{.SanitizedName}}FuzzyScoreCached -Pattern $Pattern -Candidate $option
            
            # Lower threshold to improve match rate (original threshold might be too high)
            if ($score -ge ($script:{{.SanitizedName}}_FUZZY_SCORE_THRESHOLD * 0.7)) {
                [void]$scoredMatches.Add(@{
                    Option = $option
                    Score = $score
                })
            }
        }
        
        if ($scoredMatches.Count -gt 0) {
            # Sort by score, return top N best matches
            $sortedMatches = $scoredMatches | Sort-Object Score -Descending
            
            $fuzzyResults = [System.Collections.ArrayList]::new()
            $count = 0
            foreach ($match in $sortedMatches) {
                if ($count -ge $script:{{.SanitizedName}}_FUZZY_MAX_RESULTS) { break }
                [void]$fuzzyResults.Add($match.Option)
                $count++
            }
            
            return $fuzzyResults.ToArray()
        }
    }
    
    # Final fallback: return empty array (let user know no match found)
    return @()
}

# ==================== File Path Completion Core Function ====================

# Dedicated file path completion function - provides intelligent path completion for {{.SanitizedName}}
# Parameter: $WordToComplete=the word currently being typed
# Returns: Array of matching file and directory paths
function Get-{{.SanitizedName}}PathCompletions {
    param(
        [string]$WordToComplete
    )
    
    $pathMatches = [System.Collections.ArrayList]::new()
    
    # Get the directory portion of the current path
    $basePath = if ($WordToComplete -and (Split-Path $WordToComplete -Parent)) {
        Split-Path $WordToComplete -Parent
    } else {
        "."
    }
    
    # Get the filename portion for filtering
    $fileName = if ($WordToComplete) {
        Split-Path $WordToComplete -Leaf
    } else {
        ""
    }
    
    # Pre-compile filename matching pattern
    $filePattern = "$fileName*"
    
    try {
        # Get directories and files
        $items = Get-ChildItem -Path $basePath -ErrorAction SilentlyContinue | Where-Object {
            $_.Name -like $filePattern
        }
        
        foreach ($item in $items) {
            $fullPath = if ($basePath -eq ".") {
                $item.Name
            } else {
                Join-Path $basePath $item.Name
            }
            
            # Add path separator for directories
            if ($item.PSIsContainer) {
                [void]$pathMatches.Add("$fullPath/")
            } else {
                [void]$pathMatches.Add($fullPath)
            }
        }
    }
    catch {
        # Return empty array when path access fails - silently handle errors
        Write-Debug "Path access failed: $($_.Exception.Message)"
    }
    
    return $pathMatches.ToArray()
}

# -------------------------- Completion Logic Implementation ------------------------
$scriptBlock = {
    param(
        $wordToComplete,
        $commandAst,
        $cursorPosition
    )

    # Initialize cache and index (only created on first call)
    if (-not $script:{{.SanitizedName}}_contextIndex) {
        $script:{{.SanitizedName}}_contextIndex = @{}
        $script:{{.SanitizedName}}_flagIndex = @{}
        
        # Pre-compile regex for better performance
        $script:{{.SanitizedName}}_flagRegex = [regex]::new('^-', [System.Text.RegularExpressions.RegexOptions]::Compiled)
        
        # Build context index for better lookup performance
        foreach ($item in ${{.SanitizedName}}_cmdTree) {
            if ($item.Context) {
                $script:{{.SanitizedName}}_contextIndex[$item.Context] = $item
            }
        }
        
        # Build flag index for better lookup performance
        foreach ($flag in ${{.SanitizedName}}_flagParams) {
            if ($flag.Context -and $flag.Parameter) {
                $key = "$($flag.Context)|$($flag.Parameter)"
                $script:{{.SanitizedName}}_flagIndex[$key] = $flag
            }
        }
    }

    try {
        # 1. Parse tokens
        $tokens = $commandAst.CommandElements | ForEach-Object { $_.Extent.Text }
        if (-not $tokens -or $tokens.Count -eq 0) {
            return @()
        }
        
        $currentIndex = $tokens.Count - 1
        $prevElement = if ($currentIndex -ge 1) { $tokens[$currentIndex - 1] } else { $null }

        # Fast path: if current input looks like a path, prioritize path completion
        if ($wordToComplete -match '[/\~\.]' -or $wordToComplete -like './*' -or $wordToComplete -like '../*') {
            return Get-{{.SanitizedName}}PathCompletions -WordToComplete $wordToComplete
        }

        # 2. Calculate current command context (optimized version)
        $context = "/"
        for ($i = 1; $i -le $currentIndex; $i++) {
            $elem = $tokens[$i]
            if ($script:{{.SanitizedName}}_flagRegex.IsMatch($elem)) { break }
            
            $nextContext = "$context$elem/"
            # Use index for O(1) lookup
            if ($script:{{.SanitizedName}}_contextIndex.ContainsKey($nextContext)) {
                $context = $nextContext
            } else {
                break
            }
        }

        # 3. Get available options for current context (optimized version)
        $currentContextItem = $script:{{.SanitizedName}}_contextIndex[$context]
        $currentOptions = if ($currentContextItem) { $currentContextItem.Options } else { @() }

        # Determine if currently typing flag value (previous element is flag, current input is not flag)
        $isTypingFlagValue = $prevElement -and $script:{{.SanitizedName}}_flagRegex.IsMatch($prevElement) -and -not $script:{{.SanitizedName}}_flagRegex.IsMatch($wordToComplete)

        # 4. Prioritize completing all options at current level (subcommands + flags) - use intelligent matching
        # Only execute this step when not typing flag value
        if (-not $isTypingFlagValue -and $currentOptions -and $currentOptions.Count -gt 0) {
            # Use intelligent matching to get best option matches - this is the key fix!
            $intelligentMatches = Get-{{.SanitizedName}}IntelligentMatches -Pattern $wordToComplete -Options $currentOptions

            if ($intelligentMatches.Count -gt 0) {
                # Use ArrayList to improve array operation performance
                $matchingOptions = [System.Collections.ArrayList]::new()

                foreach ($option in $intelligentMatches) {
                    $result = if ($script:{{.SanitizedName}}_flagRegex.IsMatch($option)) { $option } else { "$option " }
                    [void]$matchingOptions.Add($result)
                }

                return $matchingOptions.ToArray()
            }
        }

        # 5. Enum/preset value completion
        if ($prevElement -and $script:{{.SanitizedName}}_flagRegex.IsMatch($prevElement)) {
            $flagKey = "$context|$prevElement"
            $paramDef = $script:{{.SanitizedName}}_flagIndex[$flagKey]
            
            if ($paramDef) {
                switch ($paramDef.ValueType) {
                    'enum' {
                        # Use intelligent matching for enum value completion uniformly
                        # Returns all enum values when empty, performs intelligent matching when has value
                        $enumMatches = Get-{{.SanitizedName}}IntelligentMatches -Pattern $wordToComplete -Options $paramDef.Options
                        return $enumMatches
                    }
                    default {
                        # After string type, bool type or other type flags, user may want to input new parameter or path
                        # Use dedicated function to provide file and directory path completion
                        return Get-{{.SanitizedName}}PathCompletions -WordToComplete $wordToComplete
                    }
                }
            }
        }

         # 6. Complete flags themselves (e.g. --ty -> --type) - use intelligent matching
        if ($script:{{.SanitizedName}}_flagRegex.IsMatch($wordToComplete)) {
            # Collect all flags for current context - use ArrayList for performance optimization
            $contextFlags = [System.Collections.ArrayList]::new()
            foreach ($flag in ${{.SanitizedName}}_flagParams) {
                if ($flag.Context -eq $context) {
                    [void]$contextFlags.Add($flag.Parameter)
                }
            }
            
            if ($contextFlags.Count -gt 0) {
                # Use intelligent matching to get best flag matches
                $flagMatches = Get-{{.SanitizedName}}IntelligentMatches -Pattern $wordToComplete -Options $contextFlags.ToArray()
                if ($flagMatches.Count -gt 0) {
                    return $flagMatches
                }
            }
        }

        # 7. No match
        return @()
    }
    catch {
        # Error handling: return empty array instead of throwing exception
        Write-Debug "PowerShell completion error: $($_.Exception.Message)"
        return @()
    }
}

# ==================== Debug and Diagnostic Functions ====================

# Completion system health check function (optional, for debugging)
function Get-{{.SanitizedName}}CompletionDebug {
    Write-Host "=== {{.SanitizedName}} PowerShell Completion System Diagnostics ===" -ForegroundColor Cyan
    Write-Host "PowerShell version: $($PSVersionTable.PSVersion)" -ForegroundColor Green
    Write-Host "Completion function status: $(if (Get-Command Register-ArgumentCompleter -ErrorAction SilentlyContinue) { 'Registered' } else { 'Not registered' })" -ForegroundColor Green
    Write-Host "Command tree entry count: $(${{.SanitizedName}}_cmdTree.Count)" -ForegroundColor Green
    Write-Host "Flag parameter count: $(${{.SanitizedName}}_flagParams.Count)" -ForegroundColor Green
    Write-Host "Fuzzy completion status: $(if ($script:{{.SanitizedName}}_FUZZY_COMPLETION_ENABLED) { 'Enabled' } else { 'Disabled' })" -ForegroundColor Green
    Write-Host "Candidate threshold: $script:{{.SanitizedName}}_FUZZY_MAX_CANDIDATES" -ForegroundColor Green
    Write-Host "Cache entry count: $($script:{{.SanitizedName}}_fuzzyCache.Count)" -ForegroundColor Green
    Write-Host ""
    Write-Host "Usage: Type 'Get-{{.SanitizedName}}CompletionDebug' in PowerShell to view this information" -ForegroundColor Yellow
}

# Register completion function for both original name and sanitized name (without extension)
Register-ArgumentCompleter -CommandName '{{.ProgramName}}' -ScriptBlock $scriptBlock
Register-ArgumentCompleter -CommandName '{{.SanitizedName}}' -ScriptBlock $scriptBlock
