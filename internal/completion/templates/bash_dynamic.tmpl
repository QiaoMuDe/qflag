#!/usr/bin/env bash

# ==================== 主补全函数 ====================
_{{.ProgramName}}_complete() {
	local cur prev words cword i
	COMPREPLY=()

	# 使用 _get_comp_words_by_ref 获取补全参数以提高健壮性
	if declare -F _get_comp_words_by_ref >/dev/null 2>&1; then
		_get_comp_words_by_ref -n =: cur prev words cword
	else
		# 与旧版本 Bash 补全环境的兼容性
		words=("${COMP_WORDS[@]}")
		cword=$COMP_CWORD
		cur="${words[cword]}"
		prev="${words[cword-1]}"
	fi

	# 输入验证
	if [[ $cword -lt 0 || ${#words[@]} -eq 0 ]]; then
		return 1
	fi

	# 快速路径: 如果当前输入看起来像是路径, 优先提供路径补全
	if [[ "$cur" == *"/"* || "$cur" == *"."* || "$cur" == *"~"* ]]; then
		COMPREPLY=($(compgen -f -d -- "$cur"))
		return 0
	fi

	# 提取子命令参数 (从索引1开始, 跳过程序名) 
	local cmd_args=()
	for ((i=1; i < cword; i++)); do
		cmd_args+=("${words[i]}")
	done

	# ========== 使用 all 指令一次性获取所有补全信息 ==========
	local result candidates enum_values matches is_flag
	result=$({{.ProgramName}} __complete all "$cur" "$prev" "${cmd_args[@]}")

	# 解析结果 (按行读取, 根据前缀提取) 
	while IFS= read -r line; do
		case "$line" in
			CANDIDATES:*) candidates="${line#CANDIDATES:}" ;;
			ENUM:*) enum_values="${line#ENUM:}" ;;
			MATCHES:*) matches="${line#MATCHES:}" ;;
			IS_FLAG:*) is_flag="${line#IS_FLAG:}" ;;
		esac
	done <<< "$result"

	# 根据结果决定补全行为
	if [[ "$is_flag" == "true" ]]; then
		# 枚举类型标志, 显示匹配结果
		if [[ -n "$matches" ]]; then
			read -ra COMPREPLY <<< "$matches"
		fi
	elif [[ "$prev" =~ ^- ]]; then
		# 非枚举类型标志, 使用路径补全
		COMPREPLY=($(compgen -f -d -- "$cur"))
	elif [[ -n "$matches" ]]; then
		# 普通补全, 显示匹配结果
		read -ra COMPREPLY <<< "$matches"
	fi

	return 0
}

# 注册补全函数
complete -F _{{.ProgramName}}_complete {{.ProgramName}}
