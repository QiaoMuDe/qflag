#!/usr/bin/env bash

# ==================== Fuzzy Completion Configuration Parameters ====================
# Fuzzy completion feature switch (set to 0 to disable, 1 to enable)
{{.ProgramName}}_FUZZY_COMPLETION_ENABLED=1

# Maximum candidate count threshold for enabling fuzzy completion
# Falls back to traditional prefix matching when exceeded to ensure performance
{{.ProgramName}}_FUZZY_MAX_CANDIDATES=150

# Minimum input length for fuzzy matching (fuzzy matching disabled below this length)
{{.ProgramName}}_FUZZY_MIN_PATTERN_LENGTH=2

# Fuzzy matching score threshold (0-100, matches below this score will be filtered)
{{.ProgramName}}_FUZZY_SCORE_THRESHOLD=30

# Maximum number of fuzzy matching results to return
{{.ProgramName}}_FUZZY_MAX_RESULTS=8

# Cache size control parameter, cache will be cleared when exceeded to prevent unlimited memory growth
{{.ProgramName}}_FUZZY_CACHE_MAX_SIZE=500

# ==================== Static Data Definitions ====================
# Static command tree definition - pre-initialized outside functions
declare -A {{.ProgramName}}_cmd_tree
{{.ProgramName}}_cmd_tree["/"]="{{.RootCmdOpts}}"
{{.CmdTreeEntries}}

# Flag parameter definitions - stores type and value type (type|valueType)
declare -A {{.ProgramName}}_flag_params
{{.FlagParams}}

# Enum options definitions - stores allowed values for enum flags
declare -A {{.ProgramName}}_enum_options
{{.EnumOptions}}

# Fuzzy matching result cache (format: "pattern|candidate" -> score)
declare -A {{.ProgramName}}_fuzzy_cache

# ==================== Fuzzy Matching Core Algorithm ====================
# High-performance fuzzy scoring function - uses pure integer arithmetic to avoid bc overhead
# Parameters: $1=input pattern, $2=candidate string
# Returns: Integer score from 0-100 (output via echo)
_{{.ProgramName}}_fuzzy_score_fast() {
    local pattern="$1"
    local candidate="$2"
    local pattern_len=${#pattern}
    local candidate_len=${#candidate}
    
    # Fast path 1: Empty pattern check
    [[ -z "$pattern" ]] && { echo "100"; return; }
    
    # Fast path 2: Single character pattern optimization
    if [[ $pattern_len -eq 1 ]]; then
        local idx=$(expr index "$candidate" "$pattern")
        echo $(( idx > 0 ? 100 - idx + 1 : 0 ))
        return
    fi
    
    # Performance optimization 1: Length pre-check - return 0 if candidate is too short
    if [[ $candidate_len -lt $pattern_len ]]; then
        echo "0"
        return
    fi
    
    # Performance optimization 2: Exact match check - avoid unnecessary complex calculations
    if [[ "$candidate" == "$pattern"* ]]; then
        echo "100"  # Give highest score for exact prefix match
        return
    fi
    
    # Performance optimization 3: Character existence pre-check - quickly exclude impossible matches
    local pattern_lower="${pattern,,}"  # Convert to lowercase for case-insensitive matching
    local candidate_lower="${candidate,,}"
    local i
    for ((i=0; i<pattern_len; i++)); do
        local char="${pattern_lower:$i:1}"
        if [[ "$candidate_lower" != *"$char"* ]]; then
            echo "0"  # Required character doesn't exist, return immediately
            return
        fi
    done
    
    # Core matching algorithm - calculate character match degree and continuity
    local matched=0           # Number of matched characters
    local consecutive=0       # Current consecutive match length
    local max_consecutive=0   # Maximum consecutive match length
    local candidate_pos=0     # Current search position in candidate string
    local start_bonus=0       # Starting position bonus
    
    # Check if matches from beginning (case-insensitive)
    if [[ "$candidate_lower" == "$pattern_lower"* ]]; then
        start_bonus=20  # Give 20 points bonus for starting match
    fi
    
    # Character-by-character matching algorithm
    for ((i=0; i<pattern_len; i++)); do
        local pattern_char="${pattern_lower:$i:1}"
        local found=0
        
        # Search for current pattern character in candidate string
        for ((j=candidate_pos; j<candidate_len; j++)); do
            local candidate_char="${candidate_lower:$j:1}"
            if [[ "$pattern_char" == "$candidate_char" ]]; then
                ((matched++))
                found=1
                
                # Continuity check - consecutive matching characters score higher
                if [[ $j -eq $candidate_pos ]]; then
                    ((consecutive++))
                    if [[ $consecutive -gt $max_consecutive ]]; then
                        max_consecutive=$consecutive
                    fi
                else
                    consecutive=1  # Reset consecutive count
                fi
                
                candidate_pos=$((j+1))  # Update search position
                break
            fi
        done
        
        # Reset consecutive count if character not found
        if [[ $found -eq 0 ]]; then
            consecutive=0
        fi
    done
    
    # Score calculation - use integer arithmetic to avoid floating point and bc
    # Base score: (matched characters / pattern length) * 60
    local base_score=$((matched * 60 / pattern_len))
    
    # Consecutive bonus: (max consecutive length / pattern length) * 20
    local consecutive_bonus=$((max_consecutive * 20 / pattern_len))
    
    # Length penalty: longer candidate strings get slightly lower scores
    local length_penalty=$((candidate_len - pattern_len))
    if [[ $length_penalty -gt 10 ]]; then
        length_penalty=10  # Maximum penalty of 10 points
    fi
    
    # Final score calculation
    local final_score=$((base_score + consecutive_bonus + start_bonus - length_penalty))
    
    # Ensure score is within 0-100 range
    if [[ $final_score -lt 0 ]]; then
        final_score=0
    elif [[ $final_score -gt 100 ]]; then
        final_score=100
    fi
    
    echo "$final_score"
}

# Cached fuzzy scoring function - avoids repeated calculations to improve performance
# Parameters: $1=input pattern, $2=candidate string
_{{.ProgramName}}_fuzzy_score_cached() {
    local pattern="$1"
    local candidate="$2"
    local cache_key="${pattern}|${candidate}"
    
    # Cache hit check
    if [[ -n "${{{.ProgramName}}_fuzzy_cache[$cache_key]}" ]]; then
        echo "${{{.ProgramName}}_fuzzy_cache[$cache_key]}"
        return
    fi
    
    # Calculate score and cache
    local score
    score=$(_{{.ProgramName}}_fuzzy_score_fast "$pattern" "$candidate")
    
    # Cache size control - prevent unlimited memory growth
    if [[ ${#{{.ProgramName}}_fuzzy_cache[@]} -gt ${{.ProgramName}}_FUZZY_CACHE_MAX_SIZE ]]; then
        {{.ProgramName}}_fuzzy_cache=()  # Clear cache
    fi
    
    {{.ProgramName}}_fuzzy_cache["$cache_key"]="$score"
    echo "$score"
}

# Intelligent completion matching function - tiered matching strategy
# Parameters: $1=input pattern, $2=candidate options string (separated by |)
_{{.ProgramName}}_intelligent_match() {
    local pattern="$1"
    local options_str="$2"
    local pattern_len=${#pattern}
    
    # Parse candidate options into array
    local opts_arr
    IFS='|' read -ra opts_arr <<< "$options_str"
    local total_candidates=${#opts_arr[@]}
    
    # Pre-compute commonly used values for optimization
    local pattern_lower="${pattern,,}"
    
    # Fast path: return all options when pattern is empty
    [[ -z "$pattern" ]] && {
        COMPREPLY=("${opts_arr[@]}")
        return 0
    }
    
    # Performance protection: disable fuzzy matching when too many candidates
    if [[ $total_candidates -gt ${{.ProgramName}}_FUZZY_MAX_CANDIDATES ]]; then
        # Fall back to traditional compgen prefix matching
        local opts
        printf -v opts '%s ' "${opts_arr[@]}"
        opts="${opts% }"
        COMPREPLY=($(compgen -W "$opts" -- "$pattern"))
        return 0
    fi
    
    local matches=()
    
    # Level 1: Exact prefix matching (fastest, highest priority)
    local exact_matches=()
    local opt
    for opt in "${opts_arr[@]}"; do
        [[ "$opt" == "$pattern"* ]] && exact_matches+=("$opt")
        # Limit traversal to avoid too many exact matches
        [[ ${#exact_matches[@]} -ge 20 ]] && break
    done
    
    # If there are exact matches and count is reasonable, return directly
    if [[ ${#exact_matches[@]} -gt 0 && ${#exact_matches[@]} -le 15 ]]; then
        COMPREPLY=("${exact_matches[@]}")
        return 0
    fi
    
    # Level 2: Case-insensitive prefix matching
    if [[ ${#exact_matches[@]} -eq 0 ]]; then
        local case_insensitive_matches=()
        
        for opt in "${opts_arr[@]}"; do
            local opt_lower="${opt,,}"
            [[ "$opt_lower" == "$pattern_lower"* ]] && case_insensitive_matches+=("$opt")
        done
        
        # If there are case-insensitive matches, return
        if [[ ${#case_insensitive_matches[@]} -gt 0 ]]; then
            COMPREPLY=("${case_insensitive_matches[@]}")
            return 0
        fi
    fi
    
    # Level 3: Fuzzy matching (slowest, only use when necessary)
    if [[ ${{.ProgramName}}_FUZZY_COMPLETION_ENABLED -eq 1 && $pattern_len -ge ${{.ProgramName}}_FUZZY_MIN_PATTERN_LENGTH ]]; then
        local fuzzy_results=()
        local scored_matches=()
        
        # Fuzzy score all candidates
        for opt in "${opts_arr[@]}"; do
            local score
            score=$(_{{.ProgramName}}_fuzzy_score_cached "$pattern" "$opt")
            
            # Only keep matches that reach the threshold score
            if [[ $score -ge ${{.ProgramName}}_FUZZY_SCORE_THRESHOLD ]]; then
                scored_matches+=("$score:$opt")
            fi
        done
        
        # If there are fuzzy matching results, sort by score and return top N
        if [[ ${#scored_matches[@]} -gt 0 ]]; then
            # Sort by score in descending order
            local sorted_matches
            mapfile -t sorted_matches < <(printf '%s\n' "${scored_matches[@]}" | sort -t: -k1 -nr)
            
            # Extract option names, limit return count
            local count=0
            local match
            for match in "${sorted_matches[@]}"; do
                if [[ $count -ge ${{.ProgramName}}_FUZZY_MAX_RESULTS ]]; then
                    break
                fi
                fuzzy_results+=("${match#*:}")  # Remove score prefix
                ((count++))
            done
            
            COMPREPLY=("${fuzzy_results[@]}")
            return 0
        fi
    fi
    
    # Level 4: Substring matching (final fallback)
    local substring_matches=()
    
    for opt in "${opts_arr[@]}"; do
        local opt_lower="${opt,,}"
        [[ "$opt_lower" == *"$pattern_lower"* ]] && substring_matches+=("$opt")
    done
    
    if [[ ${#substring_matches[@]} -gt 0 ]]; then
        COMPREPLY=("${substring_matches[@]}")
        return 0
    fi
    
    # If all matching strategies fail, return empty result
    COMPREPLY=()
    return 1
}

# ==================== Main Completion Function ====================
_{{.ProgramName}}_complete() {
	local cur prev words cword context opts i arg
	COMPREPLY=()

	# Use _get_comp_words_by_ref to get completion arguments for better robustness
	if declare -F _get_comp_words_by_ref >/dev/null 2>&1; then
		_get_comp_words_by_ref -n =: cur prev words cword
	else
		# Compatibility with older Bash completion environments
		words=("${COMP_WORDS[@]}")
		cword=$COMP_CWORD
		cur="${words[cword]}"
		prev="${words[cword-1]}"
	fi

	# Input validation
	if [[ $cword -lt 0 || ${#words[@]} -eq 0 ]]; then
		return 1
	fi

	# Fast path: if current input looks like a path, prioritize path completion
	if [[ "$cur" == *"/"* || "$cur" == *"."* || "$cur" == *"~"* ]]; then
		COMPREPLY=($(compgen -f -d -- "$cur"))
		return 0
	fi

	# Find current command context
	local context="/"
	local i
	for ((i=1; i < cword; i++)); do
		local arg="${words[i]}"
		# Stop context building when encountering flags
		if [[ "$arg" =~ ^- ]]; then
			break
		fi
		
		local next_context="$context$arg/"
		# Verify context exists
		if [[ -n "${{{.ProgramName}}_cmd_tree[$next_context]}" ]]; then
			context="$next_context"
		else
			break
		fi
	done

	# Get available options for current context
	local current_context_opts="${{{.ProgramName}}_cmd_tree[$context]}"
	if [[ -z "$current_context_opts" ]]; then
		return 1
	fi
	
	# Check if previous argument requires a value and get its type
	local prev_param_type=""
	local prev_value_type=""
	if [[ $cword -gt 1 ]]; then
		local prev_arg="${words[cword-1]}"
		local key="${context}|${prev_arg}"
		local prev_param_info="${{{.ProgramName}}_flag_params[$key]:-}"
		
		if [[ -n "$prev_param_info" ]]; then
			IFS='|' read -r prev_param_type prev_value_type <<< "$prev_param_info"
		fi
	fi

	# Dynamically generate completion based on parameter type - only handle parameters that require values
	if [[ -n "$prev_param_type" && "$prev_param_type" == "required" ]]; then
		if [[ "$prev_value_type" == "enum" ]]; then
			local enum_key="${context}|${words[cword-1]}"
			local enum_opts="${{{.ProgramName}}_enum_options[$enum_key]:-}"
			
			if [[ -n "$enum_opts" ]]; then
				# Use intelligent matching for enum options
				_{{.ProgramName}}_intelligent_match "$cur" "$enum_opts"
				return 0
			fi
		else
			# Non-enum types - use file and directory path completion uniformly
			COMPREPLY=($(compgen -f -d -- "$cur"))
			return 0
		fi
	fi

	# Main flag and command completion - use intelligent matching algorithm
	_{{.ProgramName}}_intelligent_match "$cur" "$current_context_opts"
	return 0
}

# ==================== Debug and Diagnostic Functions ====================
# Completion system health check function (optional, for debugging)
_{{.ProgramName}}_completion_debug() {
    echo "=== {{.ProgramName}} Completion System Diagnostics ==="
    echo "Bash version: $BASH_VERSION"
    echo "Completion function status: $(type -t _{{.ProgramName}})"
    echo "Command tree entry count: ${#{{.ProgramName}}_cmd_tree[@]}"
    echo "Flag parameter count: ${#{{.ProgramName}}_flag_params[@]}"
    echo "Enum option count: ${#{{.ProgramName}}_enum_options[@]}"
    echo "Fuzzy completion status: $([ ${{.ProgramName}}_FUZZY_COMPLETION_ENABLED -eq 1 ] && echo "Enabled" || echo "Disabled")"
    echo "Candidate threshold: ${{.ProgramName}}_FUZZY_MAX_CANDIDATES"
    echo "Cache entry count: ${#{{.ProgramName}}_fuzzy_cache[@]}"
    echo ""
    echo "Usage: Type '_{{.ProgramName}}_completion_debug' in command line to view this information"
}

# Register completion function
complete -F _{{.ProgramName}}_complete {{.ProgramName}}
